{
  "name": "@andreibratila/tailwind-utopia",
  "private": false,
  "version": "2.0.0",
  "description": "A Tailwindcss v4 library for fluid typography and spacing with Utopia",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./cli": "./src/cli.js"
  },
  "bin": {
    "tailwind-utopia": "bin/tailwind-utopia.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreibratila/tailwind-utopia.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "tailwindcss v4",
    "utopia",
    "typography",
    "spacing",
    "fluid"
  ],
  "scripts": {
    "test": "node --test",
    "test:generate": "node ./bin/tailwind-utopia.js generate --stdout"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "author": "Andrei Bratila",
  "contributors": [
    {
      "name": "Andrei Bratila"
    }
  ],
  "license": "MIT",
  "peerDependencies": {
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "tailwindcss": "^4",
    "standard": "^17.1.0"
  }
}
